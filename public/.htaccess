# SPA fallback — todas as rotas que não são arquivos/pastas reais vão para index.html
# (necessário para o React Router em refresh/links diretos no Hostinger/Apache)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Cache de assets com hash (imutáveis)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|png|jpg|jpeg|svg|mp4)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
